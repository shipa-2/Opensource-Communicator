/* Palette-aware styles for modal windows only (not the main window). */
QWidget {
    background: transparent;
    color: palette(text);
}

QDialog {
    background: palette(window);
    font-family: "Segoe UI", "Noto Sans", sans-serif;
    font-size: 13px;
    color: palette(text);
}

QLabel {
    color: palette(text);
    background: transparent;
}

QLineEdit, QTextEdit, QPlainTextEdit, QSpinBox {
    color: palette(text);
    background: palette(base);
    border: 1px solid palette(mid);
    border-radius: 4px;
    padding: 4px 8px;
    selection-color: palette(highlightedText);
    selection-background-color: palette(highlight);
}

QLineEdit:focus, QTextEdit:focus, QPlainTextEdit:focus, QSpinBox:focus {
    border: 2px solid palette(highlight);
    padding: 3px 7px;
}

QComboBox {
    color: palette(text);
    background: palette(base);
    border: 1px solid palette(mid);
    border-radius: 4px;
    padding: 2px 8px;
}

QComboBox QAbstractItemView {
    color: palette(text);
    background: palette(base);
    selection-color: palette(highlightedText);
    selection-background-color: palette(highlight);
}

QListWidget {
    color: palette(text);
    background: palette(base);
}

QListWidget::item {
    color: palette(text);
}

QDialog#settingsDialog, QDialog#addContactDialog, QDialog#conferenceDialog {
    background: palette(base);
}

QLabel#noteHint {
    color: palette(mid);
    font-size: 12px;
}

QLabel#loginTitle {
    font-size: 20px;
    font-weight: bold;
    color: palette(text);
    background: transparent;
}

QLabel#loginSubtitle {
    font-size: 13px;
    color: palette(text);
    background: transparent;
    margin-bottom: 12px;
}

QDialog#loginDialog {
    background: palette(window);
    color: palette(text);
}

QDialog#loginDialog QLabel {
    color: palette(text);
    background: transparent;
}

QDialog#loginDialog QLineEdit {
    color: palette(text);
    background: palette(base);
    border: 1px solid palette(mid);
}

QDialog#loginDialog QLineEdit:focus {
    border: 2px solid palette(highlight);
    padding: 3px 7px;
}

QDialog#loginDialog QComboBox {
    color: palette(text);
    background: palette(base);
    border: 1px solid palette(mid);
    border-radius: 4px;
    padding: 4px 8px;
    min-height: 24px;
}

QDialog#loginDialog QComboBox:focus {
    border: 2px solid palette(highlight);
    padding: 3px 7px;
}

QDialog#loginDialog QComboBox::drop-down {
    border: none;
    width: 22px;
}

QDialog#loginDialog QComboBox QAbstractItemView {
    color: palette(text);
    background: palette(base);
    selection-color: palette(highlightedText);
    selection-background-color: palette(highlight);
}

QDialog#loginDialog QCheckBox {
    color: palette(text);
    spacing: 8px;
    margin-top: 4px;
    margin-bottom: 4px;
}

QLabel#callAvatar {
    background: palette(midlight);
    border-radius: 70px;
    font-size: 64px;
    border: 2px solid palette(highlight);
}

QLabel#callNameLabel {
    font-size: 16px;
    font-weight: bold;
    color: palette(text);
}

QLabel#callDetailLabel {
    color: palette(link);
}

QDialog#helpDialog {
    background: palette(base);
}

QDialog#callWindow {
    background: palette(window);
}

QWidget#callToolbar {
    background: palette(alternateBase);
    border-top: 1px solid palette(mid);
}

QLabel#callStatusActive {
    color: palette(highlight);
    font-weight: bold;
}

QLabel#callStatusIncoming {
    color: palette(text);
}

QLineEdit#dialEdit {
    border: 1px solid palette(mid);
    border-radius: 6px;
    padding: 8px;
    font-size: 18px;
    color: palette(text);
    background: palette(base);
}

QPushButton#dialCallBtn {
    min-height: 40px;
    font-size: 15px;
    font-weight: bold;
    border-radius: 8px;
    /* color/background are set from MainWindow::updateDialCallButtonStyle() */
}

QPushButton#logoutBtn {
    background: palette(button);
    color: #cc0000;
    border: 1px solid #cc0000;
    border-radius: 4px;
    padding: 8px 16px;
    font-weight: bold;
}

QPushButton#logoutBtn:hover {
    background: #cc0000;
    color: white;
}

QLabel#callStatusLabel {
    color: palette(text);
    font-size: 14px;
}

QLabel#callTimerLabel {
    color: palette(highlight);
    font-size: 14px;
    font-weight: bold;
}

QPushButton#callActionBtn {
    min-height: 36px;
    padding: 6px 16px;
}

QPushButton#callHangupBtn {
    min-height: 36px;
    padding: 6px 16px;
    background: palette(highlight);
    color: palette(highlightedText);
    border-radius: 4px;
    font-weight: bold;
}

QPushButton#callHangupBtn:hover {
    background: palette(highlight);
    color: palette(highlightedText);
}

QPushButton#callAnswerBtn {
    min-height: 36px;
    padding: 6px 16px;
    background: #5a9e2f;
    color: white;
    border-radius: 4px;
    font-weight: bold;
}

QPushButton#callAnswerBtn:hover {
    background: #4a8e1f;
}
